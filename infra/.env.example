# ---- LexMind AI Compose environment (copy to .env) ----

# Database
DB_NAME=lexmind
DB_USER=lexmind
DB_PASSWORD=lexmind

# Security — CHANGE THESE for any non-local deployment
JWT_SECRET=change-me-in-prod-please-use-a-strong-256-bit-secret
INTERNAL_SERVICE_TOKEN=dev-internal-service-token

# AI provider — "mock" runs with no key; set "anthropic" + key for real models
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL_STRONG=claude-opus-4-8

# Frontend origin allowed by backend CORS (frontend is served on :8081)
CORS_ORIGINS=http://localhost:8081
