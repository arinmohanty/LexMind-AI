# ---- LexMind Backend environment (copy to .env, never commit real secrets) ----
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:postgresql://localhost:5432/lexmind
DB_USERNAME=lexmind
DB_PASSWORD=lexmind

# JWT (generate a strong 256-bit secret for prod)
JWT_SECRET=change-me-in-prod-this-is-a-dev-only-256-bit-secret-key!!
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# File storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads

# AI service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=dev-internal-service-token

# CORS (frontend dev origin)
CORS_ORIGINS=http://localhost:5173
