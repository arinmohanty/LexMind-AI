# ---- LexMind AI Service ----
# LLM provider: "mock" (deterministic, no key, for dev/tests) or "anthropic"
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL_STRONG=claude-opus-4-8
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# Embeddings: "mock" or "anthropic-compatible" (extend as needed)
EMBEDDING_PROVIDER=mock

# Vector store: empty QDRANT_URL -> in-memory fallback
QDRANT_URL=
QDRANT_API_KEY=

# Internal service token shared with the backend (must match backend AI_SERVICE_TOKEN)
INTERNAL_SERVICE_TOKEN=dev-internal-service-token
BACKEND_BASE_URL=http://localhost:8080

# Pipeline tuning
MAX_CHUNK_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
RETRIEVAL_TOP_K=8
